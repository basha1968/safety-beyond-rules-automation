name: Safety Beyond Rules - Blogger to LinkedIn

on:
  schedule:
    - cron: '30 3 * * *'     # Runs daily at ~9:00 AM IST (UTC+5:30 adjustment; tweak as needed)
  workflow_dispatch:         # Manual trigger from Actions tab

jobs:
  share-latest-post:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Post latest Blogger article to LinkedIn
        uses: Arisamiga/Linkedin-RSS@master
        with:
          feed_list: 'https://safetybeyondrules.blogspot.com/feeds/posts/default'
          ln_access_token: ${{ secrets.LINKEDIN_ACCESS_TOKEN }}
          embed_image: 'true'
          # Optional: Custom message template (uses Handlebars-like vars from RSS)
          post_message: |
            New Safety Tip: {{title}}

            {{description | truncate: 180}}...

            Full article: {{link}}

            #WorkplaceSafety #NearMiss #SafetyBeyondRules #SafetyFirst
